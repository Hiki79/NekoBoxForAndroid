<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.NekoBox.ItemTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.NekoBox.ItemBody" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.NekoBox.ItemMeta" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.NekoBox.ListCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/nb_surface</item>
        <item name="cardCornerRadius">@dimen/nb_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/nb_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">?attr/colorControlHighlight</item>
    </style>

    <style name="Widget.NekoBox.FilterChip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:minHeight">36dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipCornerRadius">@dimen/nb_radius</item>
        <item name="chipStrokeColor">@color/nb_outline</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

</resources>
