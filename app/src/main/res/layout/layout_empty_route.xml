<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.NekoBox.ListCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/nb_space_sm"
    android:layout_marginTop="@dimen/nb_space_xs"
    android:layout_marginEnd="@dimen/nb_space_sm"
    android:layout_marginBottom="@dimen/nb_space_xs"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="@dimen/nb_space_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.NekoBox.ItemBody"
            android:textColor="@color/nb_text_tertiary"
            android:text="@string/route_warn"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
