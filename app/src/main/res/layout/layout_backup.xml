<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/backup_content"
            android:textAppearance="?attr/textAppearanceSubtitle1" />

        <CheckBox
            android:id="@+id/backup_configurations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:minHeight="48dp"
            android:text="@string/backup_groups_and_configurations"
            android:textAppearance="?attr/textAppearanceSubtitle2" />

        <CheckBox
            android:id="@+id/backup_rules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:minHeight="48dp"
            android:text="@string/backup_rules"
            android:textAppearance="?attr/textAppearanceSubtitle2" />

        <CheckBox
            android:id="@+id/backup_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:minHeight="48dp"
            android:text="@string/backup_settings"
            android:textAppearance="?attr/textAppearanceSubtitle2" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/backup_summary"
            android:textAppearance="?attr/textAppearanceCaption"
            android:textColor="?android:textColorSecondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/action_export"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:minHeight="48dp"
                android:text="@string/action_export"
                app:icon="@drawable/baseline_save_24" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/action_share"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:minHeight="48dp"
                android:text="@string/share"
                app:icon="@drawable/ic_social_share" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/action_import_file"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/action_import_file"
            app:icon="@drawable/ic_baseline_download_24" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/cloud_sync"
            android:textAppearance="?attr/textAppearanceSubtitle1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/cloud_sync_summary"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textColor="?android:textColorSecondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/webdav_sync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="48dp"
            android:text="@string/webdav_sync"
            app:icon="@drawable/ic_file_cloud_queue" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/reset_settings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:minHeight="48dp"
            android:text="@string/reset_settings"
            android:textColor="@color/material_red_accent_200" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
