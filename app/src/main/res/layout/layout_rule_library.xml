<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nb_surface_variant"
    android:orientation="vertical">

    <include
        layout="@layout/layout_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/searchLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/nb_space_md"
        android:layout_marginTop="@dimen/nb_space_md"
        android:layout_marginEnd="@dimen/nb_space_md"
        android:hint="@string/rule_library_search_hint"
        app:boxBackgroundColor="@color/nb_surface"
        app:boxCornerRadiusBottomEnd="@dimen/nb_radius"
        app:boxCornerRadiusBottomStart="@dimen/nb_radius"
        app:boxCornerRadiusTopEnd="@dimen/nb_radius"
        app:boxCornerRadiusTopStart="@dimen/nb_radius"
        app:endIconMode="clear_text"
        app:startIconDrawable="@drawable/ic_baseline_manage_search_24">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/searchInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:overScrollMode="never"
        android:paddingStart="@dimen/nb_space_md"
        android:paddingEnd="@dimen/nb_space_md"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/categoryGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/nb_space_sm"
            android:paddingBottom="@dimen/nb_space_xs"
            app:checkedChip="@id/categoryAll"
            app:chipSpacingHorizontal="@dimen/nb_space_sm"
            app:selectionRequired="true"
            app:singleLine="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/categoryAll"
                style="@style/Widget.NekoBox.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:checked="true"
                android:text="@string/rule_library_all" />

            <com.google.android.material.chip.Chip
                android:id="@+id/categoryStreaming"
                style="@style/Widget.NekoBox.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="@string/rule_library_streaming" />

            <com.google.android.material.chip.Chip
                android:id="@+id/categorySocial"
                style="@style/Widget.NekoBox.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="@string/rule_library_social" />

            <com.google.android.material.chip.Chip
                android:id="@+id/categoryAi"
                style="@style/Widget.NekoBox.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="@string/rule_library_ai" />

            <com.google.android.material.chip.Chip
                android:id="@+id/categoryDevelopment"
                style="@style/Widget.NekoBox.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="@string/rule_library_development" />

            <com.google.android.material.chip.Chip
                android:id="@+id/categoryGames"
                style="@style/Widget.NekoBox.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="@string/rule_library_games" />

            <com.google.android.material.chip.Chip
                android:id="@+id/categoryRegions"
                style="@style/Widget.NekoBox.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="@string/rule_library_regions" />

            <com.google.android.material.chip.Chip
                android:id="@+id/categoryAds"
                style="@style/Widget.NekoBox.FilterChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="@string/rule_library_ads" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/ruleList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="@dimen/nb_space_xs"
            android:paddingBottom="@dimen/nb_space_lg" />

        <TextView
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/rule_library_no_results"
            android:textAppearance="@style/TextAppearance.NekoBox.ItemBody"
            android:textColor="@color/nb_text_tertiary"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
